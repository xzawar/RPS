<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/green_bg">

    <!-- P2 buttons at top (rotated) -->
    <LinearLayout
        android:id="@+id/btnGroupP2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        android:rotation="180"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnP2Rock"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="✊"
            android:textSize="40sp"
            android:background="@drawable/btn_circle_game"
            android:padding="0dp"
            android:layout_marginHorizontal="12dp"/>

        <Button
            android:id="@+id/btnP2Paper"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="✋"
            android:textSize="40sp"
            android:background="@drawable/btn_circle_game"
            android:padding="0dp"
            android:layout_marginHorizontal="12dp"/>

        <Button
            android:id="@+id/btnP2Scissors"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="✌"
            android:textSize="40sp"
            android:background="@drawable/btn_circle_game"
            android:padding="0dp"
            android:layout_marginHorizontal="12dp"/>
    </LinearLayout>

    <!-- Blue rope (P2 top) -->
    <View
        android:layout_width="20dp"
        android:layout_height="0dp"
        android:background="@color/blue_rope"
        app:layout_constraintTop_toBottomOf="@id/btnGroupP2"
        app:layout_constraintBottom_toTopOf="@id/tvP2Hand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- P2 hand -->
    <TextView
        android:id="@+id/tvP2Hand"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:text="✊"
        android:textSize="70sp"
        android:gravity="center"
        android:background="@drawable/bg_white_card"
        android:elevation="6dp"
        android:rotation="180"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.28"/>

    <!-- Score bubble (left) -->
    <FrameLayout
        android:id="@+id/scoreContainer"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/shape_bubble"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintVertical_bias="0.5"
        android:layout_marginStart="8dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvScoreP2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/score_blue"/>
            <View android:layout_width="22dp" android:layout_height="1dp" android:background="@color/text_gray"/>
            <TextView
                android:id="@+id/tvScoreP1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/score_red"/>
        </LinearLayout>
    </FrameLayout>

    <!-- EXIT button (right) -->
    <TextView
        android:id="@+id/btnExit"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:text="EXIT"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:gravity="center"
        android:background="@drawable/shape_bubble"
        android:elevation="4dp"
        android:clickable="true"
        android:focusable="true"
        android:rotation="90"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5"
        android:layout_marginEnd="8dp"/>

    <!-- Result text -->
    <TextView
        android:id="@+id/tvResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:visibility="invisible"
        android:fontFamily="sans-serif-black"
        android:shadowColor="#00000066"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5"/>

    <!-- Status text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="P2 Choose!"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:fontFamily="sans-serif-black"
        android:shadowColor="#00000055"
        android:shadowDx="1"
        android:shadowDy="1"
        android:shadowRadius="3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5"/>

    <!-- P1 hand -->
    <TextView
        android:id="@+id/tvP1Hand"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:text="✊"
        android:textSize="70sp"
        android:gravity="center"
        android:background="@drawable/bg_white_card"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.72"/>

    <!-- Red rope (P1 bottom) -->
    <View
        android:layout_width="20dp"
        android:layout_height="0dp"
        android:background="@color/red_rope"
        app:layout_constraintTop_toBottomOf="@id/tvP1Hand"
        app:layout_constraintBottom_toTopOf="@id/btnGroupP1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- P1 buttons at bottom -->
    <LinearLayout
        android:id="@+id/btnGroupP1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="20dp"
        android:paddingTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnP1Rock"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="✊"
            android:textSize="40sp"
            android:background="@drawable/btn_circle_game"
            android:padding="0dp"
            android:layout_marginHorizontal="12dp"/>

        <Button
            android:id="@+id/btnP1Paper"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="✋"
            android:textSize="40sp"
            android:background="@drawable/btn_circle_game"
            android:padding="0dp"
            android:layout_marginHorizontal="12dp"/>

        <Button
            android:id="@+id/btnP1Scissors"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="✌"
            android:textSize="40sp"
            android:background="@drawable/btn_circle_game"
            android:padding="0dp"
            android:layout_marginHorizontal="12dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
