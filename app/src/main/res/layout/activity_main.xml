<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_bg">

    <!-- Green header background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:background="@drawable/bg_green_header"/>

    <!-- Decorative hand - top left -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✊"
        android:textSize="90sp"
        android:rotation="-40"
        android:translationX="-20dp"
        android:translationY="-20dp"
        android:alpha="0.35"/>

    <!-- Decorative hand - top right -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✌"
        android:textSize="90sp"
        android:rotation="25"
        android:layout_gravity="top|end"
        android:translationX="20dp"
        android:translationY="-15dp"
        android:alpha="0.35"/>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ROCK PAPER\nSCISSORS"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="70dp"
        android:fontFamily="sans-serif-black"
        android:shadowColor="#00000055"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"/>

    <!-- Star button top-right -->
    <ImageButton
        android:id="@+id/btnStar"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:src="@android:drawable/btn_star_big_off"
        android:background="@drawable/shape_bubble"
        android:padding="8dp"
        android:contentDescription="Favourite"/>

    <!-- Main white card (overlaps header) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="220dp"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Instructions -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/instructions"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:lineSpacingExtra="4dp"/>

            <Space android:layout_width="match_parent" android:layout_height="28dp"/>

            <!-- HOW TO PLAY -->
            <Button
                android:id="@+id/btnHowToPlay"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/how_to_play"
                android:background="@drawable/btn_dark"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="14sp"
                android:letterSpacing="0.06"/>

            <Space android:layout_width="match_parent" android:layout_height="12dp"/>

            <!-- PLAY VS FRIEND -->
            <LinearLayout
                android:id="@+id/btnFriend"
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:orientation="horizontal"
                android:background="@drawable/btn_blue"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="👤"
                    android:textSize="32sp"
                    android:gravity="center"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PLAY VS."
                        android:textColor="#90CAF9"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FRIEND"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"/>
                </LinearLayout>
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="12dp"/>

            <!-- PLAY VS BOT -->
            <LinearLayout
                android:id="@+id/btnBot"
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:orientation="horizontal"
                android:background="@drawable/btn_blue"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="🤖"
                    android:textSize="32sp"
                    android:gravity="center"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PLAY VS."
                        android:textColor="#90CAF9"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BOT"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"/>
                </LinearLayout>
            </LinearLayout>

            <Space android:layout_width="match_parent" android:layout_height="8dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- BACK button (bottom) -->
    <Button
        android:id="@+id/btnBack"
        android:layout_width="200dp"
        android:layout_height="54dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:text="@string/back"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@drawable/btn_salmon"/>

</FrameLayout>
