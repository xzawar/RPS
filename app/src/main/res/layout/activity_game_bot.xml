<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4CAF50">

    <!-- Blue rope from top edge to bot hand -->
    <View
        android:id="@+id/ropeBlue"
        android:layout_width="18dp"
        android:layout_height="0dp"
        android:background="@drawable/rope_blue"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/ivBotHand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bot hand (top, hanging from rope, rotated 180) -->

    <!-- Score bubble (left) -->

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivBotHand"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@color/off_white"
        android:backgroundTint="@color/white"
        android:contentDescription="@string/bot_hand_desc"
        android:rotation="180"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_hand_rock"
        app:shapeAppearanceOverlay="@style/RoundedImageView"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.176" />

    <FrameLayout
        android:id="@+id/scoreContainer"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/shape_bubble"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintVertical_bias="0.48"
        android:layout_marginStart="8dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvScorePlayer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/zero"
                android:textColor="@color/score_blue"
                android:textSize="18sp"
                android:textStyle="bold" />
            <View android:layout_width="20dp" android:layout_height="1dp" android:background="@color/text_gray"/>
            <TextView
                android:id="@+id/tvScoreBot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/zero"
                android:textColor="@color/score_red"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <!-- EXIT button (right) -->
    <TextView
        android:id="@+id/btnExit"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/shape_bubble"
        android:clickable="true"
        android:elevation="4dp"
        android:focusable="true"
        android:gravity="center"
        android:rotation="90"
        android:text="@string/exit"
        android:textColor="@color/text_dark"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.48" />

    <!-- Countdown text (big, center) -->
    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="96sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:visibility="invisible"
        android:fontFamily="sans-serif-black"
        android:alpha="0.90"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5"/>

    <!-- Result text -->
    <TextView
        android:id="@+id/tvResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:visibility="invisible"
        android:fontFamily="sans-serif-black"
        android:shadowColor="#44000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.56"/>

    <!-- Red rope from player hand to bottom -->
    <View
        android:id="@+id/ropeRed"
        android:layout_width="16dp"
        android:layout_height="315dp"
        android:background="@drawable/rope_red"
        android:elevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivPlayerHand" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivPlayerHand"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:background="@color/off_white"
        android:backgroundTint="@color/white"
        android:contentDescription="@string/player_hand_desc"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_hand_rock"
        app:shapeAppearanceOverlay="@style/RoundedImageView"
        app:layout_constraintBottom_toTopOf="@id/btnGroup"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.866" />

    <LinearLayout
        android:id="@+id/btnGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btnRock"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/btn_circle_game"
            android:padding="0dp"
            android:text="@string/emoji_rock"
            android:textSize="38sp" />

        <Button
            android:id="@+id/btnPaper"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/btn_circle_game"
            android:padding="0dp"
            android:text="@string/emoji_paper"
            android:textSize="38sp" />

        <Button
            android:id="@+id/btnScissors"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/btn_circle_game"
            android:padding="0dp"
            android:text="@string/emoji_scissors"
            android:textSize="38sp" />

    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>
