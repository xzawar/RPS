<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/green_bg">

    <!-- Blue rope from top -->
    <View
        android:id="@+id/ropeTop"
        android:layout_width="20dp"
        android:layout_height="0dp"
        android:background="@color/blue_rope"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvBotHand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bot hand (top, animating) -->
    <TextView
        android:id="@+id/tvBotHand"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:text="✊"
        android:textSize="90sp"
        android:gravity="center"
        android:background="@drawable/bg_white_card"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.2"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Score bubble (left) -->
    <FrameLayout
        android:id="@+id/scoreContainer"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/shape_bubble"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintVertical_bias="0.48"
        android:layout_marginStart="8dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/tvScorePlayer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/score_blue"/>
            <View android:layout_width="20dp" android:layout_height="1dp" android:background="@color/text_gray"/>
            <TextView
                android:id="@+id/tvScoreBot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/score_red"/>
        </LinearLayout>
    </FrameLayout>

    <!-- EXIT button (right) -->
    <TextView
        android:id="@+id/btnExit"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:text="EXIT"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark"
        android:gravity="center"
        android:background="@drawable/shape_bubble"
        android:elevation="4dp"
        android:clickable="true"
        android:focusable="true"
        android:rotation="90"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.48"
        android:layout_marginEnd="8dp"/>

    <!-- Result text (center) -->
    <TextView
        android:id="@+id/tvResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:visibility="invisible"
        android:fontFamily="sans-serif-black"
        android:shadowColor="#00000066"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.55"/>

    <!-- Countdown text -->
    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="80sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:visibility="invisible"
        android:fontFamily="sans-serif-black"
        android:alpha="0.85"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5"/>

    <!-- Red rope to bottom -->
    <View
        android:id="@+id/ropeBottom"
        android:layout_width="20dp"
        android:layout_height="0dp"
        android:background="@color/red_rope"
        app:layout_constraintTop_toBottomOf="@id/tvPlayerHand"
        app:layout_constraintBottom_toTopOf="@id/btnGroup"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Player hand (bottom, shows chosen move) -->
    <TextView
        android:id="@+id/tvPlayerHand"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:text="✊"
        android:textSize="80sp"
        android:gravity="center"
        android:background="@drawable/bg_white_card"
        android:elevation="4dp"
        android:rotation="180"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnGroup"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.85"/>

    <!-- 3 choice buttons at bottom -->
    <LinearLayout
        android:id="@+id/btnGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="20dp"
        android:paddingTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnRock"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="✊"
            android:textSize="40sp"
            android:background="@drawable/btn_circle_game"
            android:padding="0dp"
            android:layout_marginHorizontal="12dp"/>

        <Button
            android:id="@+id/btnPaper"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="✋"
            android:textSize="40sp"
            android:background="@drawable/btn_circle_game"
            android:padding="0dp"
            android:layout_marginHorizontal="12dp"/>

        <Button
            android:id="@+id/btnScissors"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:text="✌"
            android:textSize="40sp"
            android:background="@drawable/btn_circle_game"
            android:padding="0dp"
            android:layout_marginHorizontal="12dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
