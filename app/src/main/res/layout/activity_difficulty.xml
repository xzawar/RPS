<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <!-- Dark card (main content area) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="80dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/dark_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="80dp"
            android:paddingBottom="36dp"
            android:paddingHorizontal="32dp">

            <!-- Difficulty label -->
            <TextView
                android:id="@+id/tvDifficultyLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EASY"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.04"/>

            <Space android:layout_width="match_parent" android:layout_height="32dp"/>

            <!-- Custom Slider track container -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginHorizontal="8dp">

                <!-- Track background (slightly inset and translucent) -->
                <View
                    android:id="@+id/sliderTrack"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:alpha="0.2"
                    android:background="@drawable/bg_white_card"/>

                <!-- Track fill (rounded) -->
                <View
                    android:id="@+id/sliderFill"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center_vertical|start"
                    android:background="@drawable/slider_fill_bg"/>

                <!-- SeekBar (invisible, just for interaction) -->
                <SeekBar
                    android:id="@+id/seekDifficulty"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@android:color/transparent"
                    android:thumb="@drawable/slider_thumb"
                    android:thumbOffset="0dp"
                    android:splitTrack="false"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"/>
            </FrameLayout>

            <!-- Hint text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/drag_hint"
                android:textSize="14sp"
                android:textColor="#AAAAAA"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="12dp"/>

            <Space android:layout_width="match_parent" android:layout_height="40dp"/>

            <!-- PLAY button -->
            <Button
                android:id="@+id/btnPlay"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="PLAY"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/btn_salmon"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.06"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bot face circle (overlaps top of card) -->
    <FrameLayout
        android:id="@+id/botFaceContainer"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="32dp">

        <!-- Outer Glow/Border -->
        <View
            android:id="@+id/botFaceGlow"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_bubble"
            android:alpha="0.8"/>

        <!-- Inner Dark Circle -->
        <View
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_dark_card"/>

        <!-- Container for cross-fading emojis -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvBotFaceBack"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="64sp"
                android:alpha="0"/>

            <TextView
                android:id="@+id/tvBotFaceFront"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="64sp"
                android:text="😊"/>
        </FrameLayout>
    </FrameLayout>

    <!-- Back button -->
    <LinearLayout
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:padding="12dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#60;"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  Back"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

</FrameLayout>
