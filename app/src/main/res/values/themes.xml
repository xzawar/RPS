<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.RPS" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryDark">@color/green_dark</item>
        <item name="colorAccent">@color/blue_medium</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@color/green_dark</item>
        <item name="android:windowFullscreen">false</item>
    </style>
    <style name="Theme.RPS" parent="Base.Theme.RPS" />
    <style name="Theme.RPS.Dark" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/dark_bg</item>
        <item name="colorPrimaryDark">@color/dark_card</item>
        <item name="colorAccent">@color/normal_color</item>
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="android:statusBarColor">@color/dark_card</item>
    </style>
    <style name="Theme.RPS.Game" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/green_bg</item>
        <item name="android:windowBackground">@color/green_bg</item>
        <item name="android:statusBarColor">@color/green_dark</item>
    </style>
</resources>
